{
  "name": "@pseinfo/database-schema",
  "description": "TypeScript type declarations for the @pseinfo database",
  "version": "0.6.5",
  "license": "MIT",
  "author": {
    "name": "Paul Köhler",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "homepage": "https://pseinfo.github.io/database-schema",
  "repository": {
    "type": "git",
    "url": "https://github.com/pseinfo/database-schema.git"
  },
  "bugs": {
    "url": "https://github.com/pseinfo/database-schema/issues"
  },
  "keywords": [
    "database",
    "schema",
    "chemistry",
    "periodic-table",
    "elements",
    "compounds",
    "minerals",
    "nuclides",
    "types",
    "typescript",
    "type-definitions",
    "pseinfo"
  ],
  "files": [
    "enum",
    "types",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.ts",
      "default": "./types/index.ts",
      "import": "./types/index.ts"
    },
    "./abstract/*": {
      "types": "./types/abstract/*.ts",
      "default": "./types/abstract/*.ts",
      "import": "./types/abstract/*.ts"
    },
    "./collection/*": {
      "types": "./types/collection/*.ts",
      "default": "./types/collection/*.ts",
      "import": "./types/collection/*.ts"
    },
    "./entity/*": {
      "types": "./types/entity/*.ts",
      "default": "./types/entity/*.ts",
      "import": "./types/entity/*.ts"
    },
    "./enum/*": {
      "types": "./enum/*.ts",
      "default": "./enum/*.ts",
      "import": "./enum/*.ts"
    },
    "./schema.json": {
      "default": "./src/schema.json",
      "import": "./src/schema.json"
    }
  },
  "scripts": {
    "lint": "tsc",
    "docs": "typedoc --logLevel Verbose --options typedoc.json",
    "schema": "node scripts/schema.mjs",
    "schema:generate": "node scripts/schema.mjs generate",
    "schema:optimize": "node scripts/schema.mjs optimize",
    "schema:validate": "node scripts/schema.mjs validate"
  },
  "dependencies": {
    "devtypes": "^2.1.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "json-stable-stringify": "^1.3.0",
    "ts-json-schema-generator": "^2.9.0",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.2"
  }
}
